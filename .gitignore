# By default, ignore the entire output folder (it can be huge)
output/

# ...but keep small split CSVs (useful to version-control)
!output/
output/**/*
!output/splits/
!output/splits/*.csv

# Optional: keep a placeholder so empty folders stay tracked
!output/splits/.gitkeep

